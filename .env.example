# ===== Database (PostgreSQL) =====
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow

# Consumed by the backend (Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/taskflow
DB_USERNAME=taskflow
DB_PASSWORD=taskflow

# ===== Backend =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT signing secret (MUST be at least 32 chars / 256 bits). Change in production.
JWT_SECRET=change-me-in-production-this-is-a-demo-secret-key-256bits!!
JWT_EXPIRATION_MINUTES=1440

# ===== Frontend =====
# The dev server proxies /api and /ws to the backend; override if needed.
VITE_API_BASE_URL=/api
